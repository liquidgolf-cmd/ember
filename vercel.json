{
  "version": 2,
  "routes": [
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/api/chat",   "dest": "/api/chat.js" },
    { "src": "/api/tts",    "dest": "/api/tts.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js",         "dest": "/sw.js" },
    { "src": "/icons/(.*)",    "dest": "/icons/$1" },
    { "src": "/(.*)",          "dest": "/index.html" }
  ]
}
